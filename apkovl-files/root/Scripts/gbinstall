#!/bin/sh
# greenbang-install — Custom GreenBang installer for Alpine Linux
# With fallback disk setup functions if setup-disk fails

set -e

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

INSTALLER_VERSION="0.1.2-rc1"
NEWROOT="/mnt"
LIBDIR="/usr/lib"
LIBALPINE="$LIBDIR/libalpine.sh"
SCRIPTDIR="$(cd "$(dirname "$0")" && pwd)"
LIVEROOT="${LIVEROOT:-.}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ──────────────────────────────────────────────────────────────────────────────
# UTILITY FUNCTIONS
# ──────────────────────────────────────────────────────────────────────────────

info() {
    printf "${BLUE}==>${NC} %s\n" "$@"
    log_to_file "$@"
}

success() {
    printf "${GREEN}✓${NC} %s\n" "$@"
    log_to_file "✓ $@"
}

error() {
    printf "${RED}✗${NC} %s\n" "$@" >&2
    log_to_file "✗ ERROR: $@"
}

warn() {
    printf "${YELLOW}!${NC} %s\n" "$@"
    log_to_file "! WARNING: $@"
}

die() {
    error "$@"
    exit 1
}

require_root() {
    [ "$(id -u)" -eq 0 ] || die "This script must run as root"
}

load_libalpine() {
    [ -f "$LIBALPINE" ] || die "Cannot find libalpine.sh at $LIBALPINE"
    . "$LIBALPINE"
    success "Loaded Alpine utilities"
}

check_live_system() {
    [ -f /etc/apk/world ] || die "Not running from live GreenBang ISO"
    success "Running from live ISO"
}

# ──────────────────────────────────────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────────────────────────────────────

LOGFILE="/tmp/greenbang-install.log"

log_to_file() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOGFILE"
}

# ──────────────────────────────────────────────────────────────────────────────
# FALLBACK DISK SETUP FUNCTIONS
# ──────────────────────────────────────────────────────────────────────────────

# Detect EFI or BIOS mode
is_efi_boot() {
    [ -d /sys/firmware/efi ]
}

# Partition disk with sfdisk (more reliable than fdisk for scripting)
partition_disk_manual() {
    local disk="$1"
    info "Partitioning $disk (boot + root)..."

    # Clear partition table
    dd if=/dev/zero of="$disk" bs=512 count=8192 || die "Failed to clear partition table"
    sleep 2

    # Use sfdisk to create partitions (more scriptable than fdisk)
    # sfdisk format: <start> <size> <Id> [Boot]
    # We want: 512M boot (Linux 83), rest as root (Linux 83)
    sfdisk "$disk" <<SFDISK_EOF
,512M,83,*
,,83
SFDISK_EOF

    if [ $? -ne 0 ]; then
        die "Failed to partition $disk - sfdisk failed"
    fi

    sleep 2
    success "Disk partitioned"
}

# Format partitions
format_partitions_manual() {
    local disk="$1"
    local boot_part="${disk}1"
    local root_part="${disk}2"

    # Handle nvme vs sd naming
    if [ ! -e "$boot_part" ]; then
        boot_part="${disk}p1"
        root_part="${disk}p2"
    fi

    [ -b "$boot_part" ] || die "Boot partition not found: $boot_part"
    [ -b "$root_part" ] || die "Root partition not found: $root_part"

    info "Formatting partitions..."
    mkfs.vfat "$boot_part" || die "Failed to format boot partition"
    mkfs.ext4 -F "$root_part" || die "Failed to format root partition"
    success "Partitions formatted"

    # Verify partitions are actually formatted
    if ! blkid "$boot_part" >/dev/null 2>&1; then
        die "Boot partition $boot_part was not formatted correctly"
    fi
    if ! blkid "$root_part" >/dev/null 2>&1; then
        die "Root partition $root_part was not formatted correctly"
    fi

    echo "$root_part"
}

# Mount root partition and create fstab
mount_and_config_manual() {
    local root_part="$1"
    # Get boot part by replacing last digit with 1 (works for /dev/sda2, /dev/nvme0n1p2, etc)
    local boot_part=$(echo "$root_part" | sed 's/[0-9]*$/1/')

    info "Mounting filesystems..."
    mkdir -p "$NEWROOT"
    mount "$root_part" "$NEWROOT" || die "Failed to mount $root_part"

    # Create boot directory
    mkdir -p "$NEWROOT/boot"

    # Try to mount boot partition if it exists
    if [ -b "$boot_part" ]; then
        mount "$boot_part" "$NEWROOT/boot" || die "Failed to mount boot partition $boot_part"
    fi

    # Create fstab
    info "Creating fstab..."
    mkdir -p "$NEWROOT/etc"
    cat > "$NEWROOT/etc/fstab" <<EOF
# /etc/fstab: static filesystem information
$(blkid -s UUID "$root_part" | awk -F'"' '{print "UUID=" $2 " / ext4 defaults,errors=remount-ro 0 1"}')
$(blkid -s UUID "$boot_part" 2>/dev/null | awk -F'"' '{print "UUID=" $2 " /boot vfat defaults 0 2"}' || echo "")
/dev/cdrom      /media/cdrom    iso9660 noauto,ro 0 0
/dev/usbdisk    /media/usb      vfat    noauto 0 0
tmpfs           /tmp            tmpfs   nosuid,nodev 0 0
EOF

    success "Filesystems mounted and fstab created"
}

# Install bootloader
install_bootloader_manual() {
    info "Installing bootloader..."

    if is_efi_boot; then
        info "EFI detected, installing GRUB..."
        chroot "$NEWROOT" grub-install --target=x86_64-efi --efi-directory=/boot --no-nvram \
            || warn "GRUB EFI installation had issues"
        chroot "$NEWROOT" grub-mkconfig -o /boot/grub/grub.cfg \
            || warn "GRUB config generation had issues"
    else
        info "BIOS detected, installing GRUB MBR..."
        chroot "$NEWROOT" grub-install "$TARGET_DISK" \
            || warn "GRUB MBR installation had issues"
        chroot "$NEWROOT" grub-mkconfig -o /boot/grub/grub.cfg \
            || warn "GRUB config generation had issues"
    fi

    success "Bootloader installed"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 1: WELCOME & VALIDATION
# ──────────────────────────────────────────────────────────────────────────────

show_welcome() {
    clear
    printf "\n"
    printf "${GREEN}  ██████╗ ██████╗ ███████╗███████╗███╗   ██╗██████╗  █████╗ ███╗   ██╗ ██████╗${NC}\n"
    printf "${GREEN} ██╔════╝ ██╔══██╗██╔════╝██╔════╝████╗  ██║██╔══██╗██╔══██╗████╗  ██║██╔════╝${NC}\n"
    printf "${GREEN} ██║  ███╗██████╔╝█████╗  █████╗  ██╔██╗ ██║██████╔╝███████║██╔██╗ ██║██║  ███╗${NC}\n"
    printf "${GREEN} ██║   ██║██╔══██╗██╔══╝  ██╔══╝  ██║╚██╗██║██╔══██╗██╔══██║██║╚██╗██║██║   ██║${NC}\n"
    printf "${GREEN} ╚██████╔╝██║  ██║███████╗███████╗██║ ╚████║██████╔╝██║  ██║██║ ╚████║╚██████╔╝${NC}\n"
    printf "${GREEN}  ╚═════╝ ╚═╝  ╚═╝╚══════╝╚══════╝╚═╝  ╚═══╝╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝${NC}\n"
    printf "\n"
    printf "  GreenBang Installer — Alpine Linux + labwc Wayland Desktop\n"
    printf "  Version %s\n" "$INSTALLER_VERSION"
    printf "\n"
    printf "  This installer will:\n"
    printf "  1. Partition and format your target disk\n"
    printf "  2. Install Alpine Linux base system\n"
    printf "  3. Install GreenBang desktop environment\n"
    printf "  4. Configure system services and user account\n"
    printf "\n"
    printf "  WARNING: This will erase all data on the target disk.\n"
    printf "\n"
    printf "Press Enter to continue (Ctrl+C to cancel)..."
    read -r _
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 2: DISK SETUP (WITH FALLBACK)
# ──────────────────────────────────────────────────────────────────────────────

setup_disk() {
    info "Setting up disk and partitions..."

    # Ask for target disk if not provided
    if [ -z "$TARGET_DISK" ]; then
        echo ""
        echo "Available disks:"
        lsblk -d -e7,11,251 -o NAME,SIZE,MODEL
        echo ""
        printf "Enter target disk (e.g., sda): "
        read -r TARGET_DISK
        [ -n "$TARGET_DISK" ] || die "No disk specified"
        TARGET_DISK="/dev/$TARGET_DISK"
    fi

    [ -b "$TARGET_DISK" ] || die "Invalid disk: $TARGET_DISK"
    success "Target disk: $TARGET_DISK"

    # Try setup-disk first
    info "Attempting to use setup-disk..."
    if setup-disk -m sys "$TARGET_DISK" 2>/dev/null; then
        success "setup-disk completed"

        # setup-disk creates: sda1 (boot), sda2 (swap), sda3 (root)
        # or: sdap1 (boot), sdap2 (swap), sdap3 (root) for NVMe
        info "Locating root partition..."
        if [ -e "${TARGET_DISK}3" ]; then
            ROOT_PART="${TARGET_DISK}3"
            BOOT_PART="${TARGET_DISK}1"
        elif [ -e "${TARGET_DISK}p3" ]; then
            ROOT_PART="${TARGET_DISK}p3"
            BOOT_PART="${TARGET_DISK}p1"
        else
            error "Could not find root partition (expected partition 3)"
            error "Falling back to manual partitioning..."
            setup_disk_fallback
            return
        fi

        # Mount root and boot filesystems
        mkdir -p "$NEWROOT"
        if mount "$ROOT_PART" "$NEWROOT"; then
            success "Mounted $ROOT_PART to /mnt"

            # Mount boot if it's not already mounted
            mkdir -p "$NEWROOT/boot"
            if [ -b "$BOOT_PART" ] && ! mountpoint -q "$NEWROOT/boot"; then
                mount "$BOOT_PART" "$NEWROOT/boot" || warn "Could not mount boot partition"
            fi

            return
        else
            error "Failed to mount $ROOT_PART"
            error "Falling back to manual partitioning..."
            setup_disk_fallback
            return
        fi
    else
        warn "setup-disk failed or not available"
        info "Using manual disk setup..."
        setup_disk_fallback
    fi
}

setup_disk_fallback() {
    info "Using fallback disk setup (manual partitioning)..."

    partition_disk_manual "$TARGET_DISK" 2>/dev/null
    format_partitions_manual "$TARGET_DISK" 2>/dev/null

    # Determine root partition (sda2 or nvme0n1p2)
    if [ -e "${TARGET_DISK}2" ]; then
        ROOT_PART="${TARGET_DISK}2"
    elif [ -e "${TARGET_DISK}p2" ]; then
        ROOT_PART="${TARGET_DISK}p2"
    else
        die "Could not find root partition after formatting"
    fi

    mount_and_config_manual "$ROOT_PART"
    install_bootloader_manual

    success "Disk setup complete using fallback method"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 3: MIRROR & REPOSITORY CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

setup_repositories() {
    info "Configuring package repositories..."

    [ -f /etc/apk/repositories ] || die "No /etc/apk/repositories in live system"
    mkdir -p "$NEWROOT/etc/apk"
    cp /etc/apk/repositories "$NEWROOT/etc/apk/repositories"
    success "Repositories configured"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 4: BASE SYSTEM INSTALLATION
# ──────────────────────────────────────────────────────────────────────────────

install_base_packages() {
    info "Installing base Alpine system to $NEWROOT..."

    # Copy live system's apk configuration and keys to target
    # This includes repositories, signing keys, and cache
    info "Copying apk configuration from live system..."
    mkdir -p "$NEWROOT/etc/apk"
    [ -d /etc/apk/keys ] && cp -r /etc/apk/keys "$NEWROOT/etc/apk/" || true
    mkdir -p "$NEWROOT/var/lib/apk"
    mkdir -p "$NEWROOT/etc/apk/cache"

    # Initialize APK database
    apk init-db --root "$NEWROOT" 2>/dev/null || {
        warn "Could not initialize APK database (will try anyway)"
    }

    WORLD_FILE="${LIVEROOT}/etc/apk/world"

    if [ ! -f "$WORLD_FILE" ]; then
        warn "Using live system packages from /etc/apk/world"
        WORLD_FILE="/etc/apk/world"
    fi

    # Install packages to target root
    info "Installing packages..."
    apk add --root "$NEWROOT" \
        --repository "$NEWROOT/etc/apk/repositories" \
        alpine-base linux-lts grub grub-efi \
        $(grep -v '^#' "$WORLD_FILE" | grep -v '^$') \
        || die "Package installation failed"

    success "Base system installed"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 5: GREENBANG CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

copy_greenbang_configs() {
    info "Copying GreenBang configuration files..."

    # Try multiple locations for skel directory
    APKOVL_SRC=""
    if [ -d "/etc/skel" ]; then
        APKOVL_SRC="/etc/skel"
    elif [ -d "${LIVEROOT}/etc/skel" ]; then
        APKOVL_SRC="${LIVEROOT}/etc/skel"
    fi

    if [ -z "$APKOVL_SRC" ] || [ ! -d "$APKOVL_SRC" ]; then
        warn "GreenBang configs not found, skipping skel copy"
        return
    fi

    mkdir -p "$NEWROOT/etc/skel"
    cp -a "$APKOVL_SRC/." "$NEWROOT/etc/skel/" 2>/dev/null || {
        error "Failed to copy some skel files (continuing...)"
    }

    if [ -d /etc/doas.d ]; then
        mkdir -p "$NEWROOT/etc/doas.d"
        cp /etc/doas.d/doas.conf "$NEWROOT/etc/doas.d/doas.conf" 2>/dev/null || true
        chmod 0400 "$NEWROOT/etc/doas.d/doas.conf"
    fi

    if [ -d /etc/NetworkManager ]; then
        mkdir -p "$NEWROOT/etc/NetworkManager/conf.d"
        cp /etc/NetworkManager/NetworkManager.conf "$NEWROOT/etc/NetworkManager/" 2>/dev/null || true
        cp /etc/NetworkManager/conf.d/* "$NEWROOT/etc/NetworkManager/conf.d/" 2>/dev/null || true
    fi

    success "GreenBang configs copied"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 6: USER SETUP
# ──────────────────────────────────────────────────────────────────────────────

create_admin_user() {
    info "Creating admin user..."

    printf "Admin username [admin]: "
    read -r ADMIN_USER
    ADMIN_USER="${ADMIN_USER:-admin}"

    # Prompt for password with input suppression
    printf "Admin password: "
    read -rs ADMIN_PASS
    printf "\n"
    
    printf "Confirm password: "
    read -rs ADMIN_PASS_CONFIRM
    printf "\n"

    [ "$ADMIN_PASS" = "$ADMIN_PASS_CONFIRM" ] || die "Passwords do not match"
    [ -n "$ADMIN_PASS" ] || die "Password cannot be empty"

    # Create user with home directory
    chroot "$NEWROOT" adduser -D -G wheel "$ADMIN_USER" || die "Failed to create user $ADMIN_USER"
    
    # Verify user was created
    chroot "$NEWROOT" id "$ADMIN_USER" >/dev/null 2>&1 || die "User $ADMIN_USER was not created successfully"

    # Add to additional groups
    for group in audio video input seat; do
        chroot "$NEWROOT" addgroup "$ADMIN_USER" "$group" 2>/dev/null || true
    done

    # Set password securely (use printf to avoid variable exposure in ps)
    printf "%s:%s\n" "$ADMIN_USER" "$ADMIN_PASS" | chroot "$NEWROOT" chpasswd
    
    # Clear password variables from memory
    ADMIN_PASS=""
    ADMIN_PASS_CONFIRM=""

    # Set up home directory
    mkdir -p "$NEWROOT/home/$ADMIN_USER"

    if [ -d "$NEWROOT/etc/skel" ]; then
        cp -a "$NEWROOT/etc/skel/." "$NEWROOT/home/$ADMIN_USER/" 2>/dev/null || true
    fi

    # Try chown from inside chroot first, fall back to numeric UID/GID
    if ! chroot "$NEWROOT" chown -R "$ADMIN_USER:$ADMIN_USER" "/home/$ADMIN_USER" 2>/dev/null; then
        # Get UID/GID from /etc/passwd in chroot
        UID=$(chroot "$NEWROOT" grep "^$ADMIN_USER:" /etc/passwd | cut -d: -f3)
        GID=$(chroot "$NEWROOT" grep "^$ADMIN_USER:" /etc/passwd | cut -d: -f4)
        if [ -n "$UID" ] && [ -n "$GID" ]; then
            chown -R "$UID:$GID" "$NEWROOT/home/$ADMIN_USER" || warn "Could not set home directory ownership"
        else
            warn "Could not determine user UID/GID for chown"
        fi
    fi

    success "Admin user created: $ADMIN_USER"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 7: SYSTEM SERVICES & BOOTLOADER
# ──────────────────────────────────────────────────────────────────────────────

setup_services() {
    info "Configuring system services..."

    chroot "$NEWROOT" rc-update add dbus default 2>/dev/null || true
    chroot "$NEWROOT" rc-update add networkmanager default 2>/dev/null || true
    chroot "$NEWROOT" rc-update add seatd default 2>/dev/null || true

    success "Services configured"
}

setup_bootloader() {
    info "Configuring bootloader..."

    # Mount essential filesystems for bootloader tools
    mkdir -p "$NEWROOT/proc" "$NEWROOT/sys" "$NEWROOT/dev"
    mount -t proc proc "$NEWROOT/proc" 2>/dev/null || true
    mount -t sysfs sys "$NEWROOT/sys" 2>/dev/null || true
    mount -o bind /dev "$NEWROOT/dev" 2>/dev/null || true

    chroot "$NEWROOT" mkinitfs -k all || {
        warn "mkinitfs had issues (this might be OK)"
    }

    if chroot "$NEWROOT" test -d /boot/grub 2>/dev/null; then
        info "Updating GRUB bootloader..."
        chroot "$NEWROOT" grub-mkconfig -o /boot/grub/grub.cfg || {
            warn "GRUB config generation had issues"
        }
    else
        info "Updating extlinux bootloader..."
        chroot "$NEWROOT" update-extlinux || {
            warn "extlinux update had issues"
        }
    fi

    success "Bootloader configured"
}

# ──────────────────────────────────────────────────────────────────────────────
# PHASE 8: FINAL SETUP & CLEANUP
# ──────────────────────────────────────────────────────────────────────────────

finalize_installation() {
    info "Finalizing installation..."

    # Copy logfile to installed system for debugging
    if [ -f "$LOGFILE" ]; then
        mkdir -p "$NEWROOT/var/log"
        cp "$LOGFILE" "$NEWROOT/var/log/greenbang-install.log"
        success "Installation log saved to /var/log/greenbang-install.log"
    fi

    if [ -z "$HOSTNAME_SET" ]; then
        while true; do
            printf "Hostname [greenbang]: "
            read -r HOSTNAME
            HOSTNAME="${HOSTNAME:-greenbang}"
            
            if validate_hostname "$HOSTNAME"; then
                echo "$HOSTNAME" > "$NEWROOT/etc/hostname"
                break
            else
                error "Invalid hostname. Use alphanumeric characters and hyphens only (1-63 characters)"
            fi
        done
    fi

    if [ ! -f "$NEWROOT/etc/fstab" ]; then
        warn "No fstab found, creating minimal one"
        cat > "$NEWROOT/etc/fstab" <<EOF
/dev/cdrom      /media/cdrom    iso9660 noauto,ro 0 0
/dev/usbdisk    /media/usb      vfat    noauto 0 0
tmpfs           /tmp            tmpfs   nosuid,nodev 0 0
EOF
    fi

    success "Installation finalized"
}

unmount_filesystems() {
    info "Unmounting filesystems..."

    # Unmount in reverse order
    umount -l "$NEWROOT/proc" 2>/dev/null || true
    umount -l "$NEWROOT/sys" 2>/dev/null || true
    umount -l "$NEWROOT/dev" 2>/dev/null || true
    umount -l "$NEWROOT/boot" 2>/dev/null || true

    sync
    # Try multiple times if needed
    for i in {1..5}; do
        if umount -l "$NEWROOT" 2>/dev/null; then
            break
        fi
        if [ $i -lt 5 ]; then
            sleep 1
        fi
    done

    if mountpoint -q "$NEWROOT" 2>/dev/null; then
        warn "Could not unmount $NEWROOT (may still be in use)"
    fi

    success "Filesystems unmounted"
}

# ──────────────────────────────────────────────────────────────────────────────
# HOSTNAME VALIDATION
# ──────────────────────────────────────────────────────────────────────────────

validate_hostname() {
    local hostname="$1"
    # Check: alphanumeric + hyphens only, 1-63 chars
    if echo "$hostname" | grep -qE '^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?$'; then
        return 0
    else
        return 1
    fi
}


# Create inittab for installed system (no autologin)
setup_inittab() {
    info "Setting up inittab for installed system..."
    
    cat > "$NEWROOT/etc/inittab" <<'INITTAB_EOF'
# /etc/inittab

::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

# Set up a couple of getty's (no autologin for installed system)
tty1::respawn:/sbin/agetty 38400 tty1 linux
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3
tty4::respawn:/sbin/getty 38400 tty4
tty5::respawn:/sbin/getty 38400 tty5
tty6::respawn:/sbin/getty 38400 tty6

# Put a getty on the serial port
#ttyS0::respawn:/sbin/getty -L 115200 ttyS0 vt100

# Stuff to do for the 3-finger salute
::ctrlaltdel:/sbin/reboot

# Stuff to do before rebooting
::shutdown:/sbin/openrc shutdown

# enable login on alternative console
ttyS0::respawn:/sbin/getty -L 0 ttyS0 vt100
INITTAB_EOF

    success "inittab configured"
}

# ──────────────────────────────────────────────────────────────────────────────
# MAIN EXECUTION
# ──────────────────────────────────────────────────────────────────────────────

main() {
    require_root
    load_libalpine
    check_live_system

    show_welcome

    info "Starting GreenBang installation..."

    info "Phase 2: Disk setup..."
    setup_disk || die "Disk setup failed"

    info "Phase 3: Repository configuration..."
    setup_repositories || die "Repository setup failed"

    info "Phase 4: Base system installation..."
    install_base_packages || die "Package installation failed"

    info "Phase 5: GreenBang configuration..."
    copy_greenbang_configs || die "Config copy failed"
    setup_inittab || die "inittab setup failed"

    info "Phase 6: User setup..."
    create_admin_user || die "User creation failed"

    info "Phase 7: Services and bootloader..."
    setup_services || die "Service setup failed"
    setup_bootloader || die "Bootloader setup failed"

    info "Phase 8: Finalization..."
    finalize_installation || die "Finalization failed"

    info "Phase 9: Cleanup..."
    unmount_filesystems || die "Unmounting failed"

    echo ""
    success "Installation complete!"
    echo ""
    echo "Summary:"
    echo "  Target disk: $TARGET_DISK"
    echo "  Admin user: $ADMIN_USER"
    echo "  Hostname: $HOSTNAME"
    echo ""
    echo "Next steps:"
    echo "  1. Remove installation media"
    echo "  2. Reboot the system"
    echo "  3. Login with: $ADMIN_USER"
    echo ""

    printf "Ready to reboot? [y/N] "
    read -r REBOOT
    if [ "$REBOOT" = "y" ] || [ "$REBOOT" = "Y" ]; then
        reboot
    fi
}

main "$@"
