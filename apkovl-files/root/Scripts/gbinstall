#!/bin/sh
# greenbang-install — GreenBang disk installer
# Uses Alpine setup-* scripts for standard tasks

set -e

INSTALLER_VERSION=0.2.0
NEWROOT=/mnt
LOGFILE=/tmp/greenbang-install.log

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ── Utilities ──────────────────────────────────────────────────────────────────

info() { printf "${BLUE}==>${NC} %s\n" "$*"; log "$*"; }
ok()   { printf "${GREEN}  ok${NC} %s\n" "$*"; log "ok: $*"; }
warn() { printf "${YELLOW}  !${NC} %s\n" "$*"; log "warn: $*"; }
die()  { printf "${RED}  !${NC} %s\n" "$*" >&2; log "error: $*"; exit 1; }
log()  { echo "[$(date "+%H:%M:%S")] $*" >> "$LOGFILE"; }

require_root() { [ "$(id -u)" -eq 0 ] || die "Must be run as root"; }
check_live()   { [ -f /etc/apk/world ] || die "Not running from GreenBang live ISO"; }

# ── Welcome ────────────────────────────────────────────────────────────────────

show_welcome() {
    clear
    printf "\n"
    printf "${GREEN}  ██████╗ ██████╗ ███████╗███████╗███╗   ██╗██████╗  █████╗ ███╗   ██╗ ██████╗ ${NC}\n"
    printf "${GREEN} ██╔════╝ ██╔══██╗██╔════╝██╔════╝████╗  ██║██╔══██╗██╔══██╗████╗  ██║██╔════╝ ${NC}\n"
    printf "${GREEN} ██║  ███╗██████╔╝█████╗  █████╗  ██╔██╗ ██║██████╔╝███████║██╔██╗ ██║██║  ███╗${NC}\n"
    printf "${GREEN} ██║   ██║██╔══██╗██╔══╝  ██╔══╝  ██║╚██╗██║██╔══██╗██╔══██║██║╚██╗██║██║   ██║${NC}\n"
    printf "${GREEN} ╚██████╔╝██║  ██║███████╗███████╗██║ ╚████║██████╔╝██║  ██║██║ ╚████║╚██████╔╝${NC}\n"
    printf "${GREEN}  ╚═════╝ ╚═╝  ╚═╝╚══════╝╚══════╝╚═╝  ╚═══╝╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝${NC}\n"
    printf "\n"
    printf "  GreenBang Installer v%s\n" "$INSTALLER_VERSION"
    printf "  Alpine Linux + labwc Wayland Desktop\n"
    printf "\n"
    printf "  ${YELLOW}WARNING: This will erase all data on the target disk.${NC}\n"
    printf "\n"
    printf "Press Enter to continue or Ctrl+C to cancel... "
    read -r _
}

# ── Phase 2: Disk ──────────────────────────────────────────────────────────────

disk_fallback() {
    local disk="$1"
    info "Manual partitioning $disk..."

    dd if=/dev/zero of="$disk" bs=512 count=8192 2>/dev/null
    sleep 1

    if [ -d /sys/firmware/efi ]; then
        printf "label: gpt\n,512M,U\n,,L\n" | sfdisk "$disk" || die "sfdisk failed"
    else
        printf ",512M,83,*\n,,83\n" | sfdisk "$disk" || die "sfdisk failed"
    fi
    sleep 1

    if [ -e "${disk}1" ]; then
        BOOT_PART="${disk}1"; ROOT_PART="${disk}2"
    else
        BOOT_PART="${disk}p1"; ROOT_PART="${disk}p2"
    fi

    if [ -d /sys/firmware/efi ]; then
        mkfs.vfat -F32 "$BOOT_PART" || die "Failed to format EFI partition"
    else
        mkfs.ext2 "$BOOT_PART" || die "Failed to format boot partition"
    fi
    mkfs.ext4 -F "$ROOT_PART" || die "Failed to format root partition"

    mkdir -p "$NEWROOT"
    mount "$ROOT_PART" "$NEWROOT" || die "Failed to mount $ROOT_PART"
    mkdir -p "$NEWROOT/boot"
    mount "$BOOT_PART" "$NEWROOT/boot" || die "Failed to mount $BOOT_PART"

    mkdir -p "$NEWROOT/etc"
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    BOOT_UUID=$(blkid -s UUID -o value "$BOOT_PART")
    FS_BOOT=$([ -d /sys/firmware/efi ] && echo vfat || echo ext2)
    printf "UUID=%s  /      ext4  defaults,errors=remount-ro  0 1\nUUID=%s  /boot  %s  defaults  0 2\ntmpfs  /tmp  tmpfs  nosuid,nodev  0 0\n"         "$ROOT_UUID" "$BOOT_UUID" "$FS_BOOT" > "$NEWROOT/etc/fstab"

    ok "Disk ready (fallback)"
}

setup_disk_phase() {
    info "Disk setup"
    echo ""
    echo "Available disks:"
    lsblk -d -e 7,11 -o NAME,SIZE,MODEL 2>/dev/null
    echo ""
    printf "Target disk (e.g. sda): "
    read -r _disk
    [ -n "$_disk" ] || die "No disk specified"
    TARGET_DISK="/dev/$_disk"
    [ -b "$TARGET_DISK" ] || die "Not a block device: $TARGET_DISK"

    if setup-disk -m sys "$TARGET_DISK" 2>/dev/null; then
        if [ -e "${TARGET_DISK}3" ]; then
            ROOT_PART="${TARGET_DISK}3"
        elif [ -e "${TARGET_DISK}p3" ]; then
            ROOT_PART="${TARGET_DISK}p3"
        else
            warn "Cannot locate root partition, using fallback"
            disk_fallback "$TARGET_DISK"; return
        fi
        mkdir -p "$NEWROOT"
        mount "$ROOT_PART" "$NEWROOT" || { warn "Mount failed, using fallback"; disk_fallback "$TARGET_DISK"; return; }
        ok "setup-disk complete"
    else
        warn "setup-disk failed, using fallback"
        disk_fallback "$TARGET_DISK"
    fi
}

# ── Phase 3: Repositories ──────────────────────────────────────────────────────

setup_repos_phase() {
    info "Repository configuration"
    mkdir -p "$NEWROOT/etc/apk"
    cp -r /etc/apk/keys "$NEWROOT/etc/apk/" 2>/dev/null || true
    ROOT="$NEWROOT" setup-apkrepos
    ok "Repositories configured"
}

# ── Phase 4: Base install ──────────────────────────────────────────────────────

install_base_phase() {
    info "Installing base system (this will take a few minutes)..."

    apk --root "$NEWROOT" --initdb add 2>/dev/null || true

    PKGS="alpine-base linux-lts grub grub-efi mkinitfs $(grep -v '^#' /etc/apk/world | grep -v '^$' | tr '\n' ' ')"

    # shellcheck disable=SC2086
    apk --root "$NEWROOT"         --repositories-file "$NEWROOT/etc/apk/repositories"         add $PKGS || die "Package installation failed"

    ok "Base system installed"
}

# ── Phase 5: System config ─────────────────────────────────────────────────────

setup_system_phase() {
    info "Keymap"
    ROOT="$NEWROOT" setup-keymap

    info "Timezone"
    ROOT="$NEWROOT" setup-timezone

    info "Hostname"
    ROOT="$NEWROOT" setup-hostname

    info "NTP (chrony)"
    ROOT="$NEWROOT" setup-ntp chrony

    ok "System configured"
}

# ── Phase 6: Wayland base ──────────────────────────────────────────────────────

setup_wayland_phase() {
    info "Wayland base"
    ROOT="$NEWROOT" setup-wayland-base
    ok "elogind and polkit configured"
}

# ── Phase 7: GreenBang configs ─────────────────────────────────────────────────

copy_configs_phase() {
    info "Copying GreenBang configs..."

    if [ -d /etc/skel ]; then
        mkdir -p "$NEWROOT/etc/skel"
        cp -a /etc/skel/. "$NEWROOT/etc/skel/"
        ok "skel (labwc, waybar, foot, mako, conky, gtk, backgrounds, scripts)"
    fi

    if [ -d /etc/NetworkManager ]; then
        mkdir -p "$NEWROOT/etc/NetworkManager/conf.d"
        cp /etc/NetworkManager/NetworkManager.conf "$NEWROOT/etc/NetworkManager/" 2>/dev/null || true
        cp /etc/NetworkManager/conf.d/*.conf "$NEWROOT/etc/NetworkManager/conf.d/" 2>/dev/null || true
        ok "NetworkManager config"
    fi

    cat > "$NEWROOT/etc/inittab" <<'INITTAB'
::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

tty1::respawn:/sbin/agetty 38400 tty1 linux
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3
tty4::respawn:/sbin/getty 38400 tty4
tty5::respawn:/sbin/getty 38400 tty5
tty6::respawn:/sbin/getty 38400 tty6

::ctrlaltdel:/sbin/reboot
::shutdown:/sbin/openrc shutdown
INITTAB
    ok "inittab"
}

# ── Phase 8: User ──────────────────────────────────────────────────────────────

setup_user_phase() {
    info "User account"
    ROOT="$NEWROOT" setup-user -a -g "audio,video,input,seat"

    NEWUSER=$(awk -F: '$3 >= 1000 && $3 < 65534 {print $1}' "$NEWROOT/etc/passwd" | tail -1)

    if [ -n "$NEWUSER" ] && [ -d "$NEWROOT/etc/skel" ]; then
        cp -a "$NEWROOT/etc/skel/." "$NEWROOT/home/$NEWUSER/"
        NUID=$(awk -F: -v u="$NEWUSER" '$1==u{print $3}' "$NEWROOT/etc/passwd")
        NGID=$(awk -F: -v u="$NEWUSER" '$1==u{print $4}' "$NEWROOT/etc/passwd")
        chown -R "$NUID:$NGID" "$NEWROOT/home/$NEWUSER" 2>/dev/null || true
        ok "Home directory populated for $NEWUSER"
    fi
}

# ── Phase 9: Services ──────────────────────────────────────────────────────────

setup_services_phase() {
    info "Enabling services..."
    for svc in dbus networkmanager seatd elogind chrony; do
        chroot "$NEWROOT" rc-update add "$svc" default 2>/dev/null && ok "$svc" || warn "$svc not available"
    done
    for svc in pipewire wireplumber; do
        chroot "$NEWROOT" rc-update add "$svc" default 2>/dev/null && ok "$svc" || warn "$svc not available"
    done
}

# ── Phase 10: Bootloader ───────────────────────────────────────────────────────

setup_bootloader_phase() {
    info "Bootloader"

    mount -t proc proc "$NEWROOT/proc" 2>/dev/null || true
    mount -t sysfs sys "$NEWROOT/sys" 2>/dev/null || true
    mount --rbind /dev "$NEWROOT/dev" 2>/dev/null || true
    [ -d /sys/firmware/efi ] && mount --rbind /sys/firmware/efi "$NEWROOT/sys/firmware/efi" 2>/dev/null || true

    chroot "$NEWROOT" mkinitfs || warn "mkinitfs had issues"

    if [ -d /sys/firmware/efi ]; then
        chroot "$NEWROOT" grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=GreenBang || warn "grub-install had issues"
    else
        chroot "$NEWROOT" grub-install "$TARGET_DISK" || warn "grub-install had issues"
    fi

    chroot "$NEWROOT" grub-mkconfig -o /boot/grub/grub.cfg || warn "grub-mkconfig had issues"

    ok "Bootloader installed"
}

# ── Phase 11: Finish ───────────────────────────────────────────────────────────

finish_phase() {
    info "Cleaning up..."

    cp "$LOGFILE" "$NEWROOT/var/log/greenbang-install.log" 2>/dev/null || true

    umount -l "$NEWROOT/proc" 2>/dev/null || true
    umount -l "$NEWROOT/sys" 2>/dev/null || true
    umount -l "$NEWROOT/dev" 2>/dev/null || true
    umount -l "$NEWROOT/boot" 2>/dev/null || true
    sync
    umount -l "$NEWROOT" 2>/dev/null || true

    printf "\n"
    printf "${GREEN}  Installation complete!${NC}\n"
    printf "\n"
    printf "  Remove the installation media and reboot.\n"
    printf "\n"
    printf "Reboot now? [y/N] "
    read -r _r
    [ "$_r" = "y" ] || [ "$_r" = "Y" ] && reboot || true
}

# ── Main ───────────────────────────────────────────────────────────────────────

main() {
    require_root
    check_live
    show_welcome

    setup_disk_phase
    setup_repos_phase
    install_base_phase
    setup_system_phase
    setup_wayland_phase
    copy_configs_phase
    setup_user_phase
    setup_services_phase
    setup_bootloader_phase
    finish_phase
}

main $@
