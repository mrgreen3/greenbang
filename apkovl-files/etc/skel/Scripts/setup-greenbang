#!/bin/sh
# setup-greenbang — GreenBang installer
# Wraps setup-alpine, then copies GreenBang configs to the installed system.

# ── must run as root ──────────────────────────────────────────────────────────

if [ "$(id -u)" -ne 0 ]; then
    exec doas "$0" "$@"
fi

# ── welcome ───────────────────────────────────────────────────────────────────

clear
cat <<'EOF'

  ██████╗ ██████╗ ███████╗███████╗███╗   ██╗██████╗  █████╗ ███╗   ██╗ ██████╗
 ██╔════╝ ██╔══██╗██╔════╝██╔════╝████╗  ██║██╔══██╗██╔══██╗████╗  ██║██╔════╝
 ██║  ███╗██████╔╝█████╗  █████╗  ██╔██╗ ██║██████╔╝███████║██╔██╗ ██║██║  ███╗
 ██║   ██║██╔══██╗██╔══╝  ██╔══╝  ██║╚██╗██║██╔══██╗██╔══██║██║╚██╗██║██║   ██║
 ╚██████╔╝██║  ██║███████╗███████╗██║ ╚████║██████╔╝██║  ██║██║ ╚████║╚██████╔╝
  ╚═════╝ ╚═╝  ╚═╝╚══════╝╚══════╝╚═╝  ╚═══╝╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝

  Install GreenBang to disk — Alpine base + labwc Wayland desktop

  Network is already active (NetworkManager). When prompted for disk mode,
  choose 'sys' to install to disk.

EOF

printf "Press Enter to begin..."
read -r _

# ── base install ──────────────────────────────────────────────────────────────

setup-alpine

# ── post-install: copy GreenBang configs ─────────────────────────────────────

NEWROOT=/mnt

# Only run post-install if setup-disk did a sys install
if ! mountpoint -q "$NEWROOT" 2>/dev/null; then
    echo "No system mounted at $NEWROOT — skipping GreenBang config copy."
    exit 0
fi

# Extract installed username (first non-root, non-system user)
INSTALLED_USER=$(chroot "$NEWROOT" sed -n '/^[^:]*:[^:]*:[1-9][0-9]*:/p' /etc/passwd | head -1 | cut -d: -f1)

echo ""
echo "==> Copying GreenBang configuration to installed system..."

# Remove live user creation script — not needed on installed system
rm -f "$NEWROOT/etc/local.d/greenbang-setup.start"

# skel (desktop configs land here for all new users)
if [ -d /etc/skel ]; then
    cp -a /etc/skel/. "$NEWROOT/etc/skel/"
fi

# doas
if [ -f /etc/doas.d/doas.conf ]; then
    install -D -m 0400 /etc/doas.d/doas.conf "$NEWROOT/etc/doas.d/doas.conf"
fi

# Install packages from live system world file
if [ -f /etc/apk/world ]; then
    echo "==> Installing packages from live system..."
    cp /etc/apk/world "$NEWROOT/etc/apk/world"
    chroot "$NEWROOT" apk add $(cat /etc/apk/world)
fi

# Enable services to match live system
echo "==> Enabling system services..."
chroot "$NEWROOT" rc-update add dbus default
chroot "$NEWROOT" rc-update add networkmanager default
chroot "$NEWROOT" rc-update add seatd default

# Configure installed user with required group memberships
if [ -n "$INSTALLED_USER" ]; then
    echo "==> Adding user to groups..."
    for group in wheel audio video input seat; do
        chroot "$NEWROOT" addgroup "$INSTALLED_USER" "$group" 2>/dev/null || true
    done
fi

# Installation summary
echo ""
echo "==> Installation Summary"
echo "    User:     $INSTALLED_USER"
echo "    Groups:   wheel, audio, video, input, seat"
echo "    Services: dbus, networkmanager, seatd"
echo ""
echo "==> Installation complete."
echo "    Remove install media and reboot to finish setup."
echo ""
