#!/bin/sh

# Configure VM display output (QEMU Virtual-1)
wlr-randr | grep -q Virtual-1 && wlr-randr --output Virtual-1 --mode 1920x1080 &

# Restart NetworkManager (ensure it's fully initialized)
doas rc-service networkmanager restart &

# Update D-Bus environment for Wayland session
dbus-update-activation-environment DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP &

# Start PipeWire audio stack via OpenRC user services (Alpine >= 3.22 method)
openrc-user gui &

# Set wallpaper
swaybg -i $HOME/Backgrounds/seafront.jpg -m fill &

# Start waybar
waybar &

# Notification daemon
mako &

# Network manager applet
nm-applet &

# System monitor
conky &
