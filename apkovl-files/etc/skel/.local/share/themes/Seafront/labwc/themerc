window.inactive.button.unpressed.image.color: #6c7086

window.active.shadow.size: 80
window.inactive.shadow.size: 50
window.active.shadow.color: #000000ff
window.inactive.shadow.color: #000000ff

menu.items.bg.color: #1e1e1eCC
